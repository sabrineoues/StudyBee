# StudyBee (Django) - Email configuration
#
# SendGrid SMTP setup (recommended):
# - Create a SendGrid API Key (Mail Send)
# - Verify a sender identity in SendGrid
# - Put that sender in DJANGO_DEFAULT_FROM_EMAIL
#
# In development you can keep the console backend to print emails in the terminal.

# --- Frontend base URL used inside reset password emails
STUDYBEE_FRONTEND_URL=http://localhost:5173

# --- Email backend
# Dev (prints emails):
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Prod/SendGrid SMTP:
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# --- SendGrid SMTP (defaults already match SendGrid if you omit host/user)
DJANGO_EMAIL_HOST=smtp.sendgrid.net
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_HOST_USER=apikey

# IMPORTANT: set this to your SendGrid API key (starts with SG.)
DJANGO_EMAIL_HOST_PASSWORD=SG_your_sendgrid_api_key_here

# Must be a verified sender in SendGrid
DJANGO_DEFAULT_FROM_EMAIL=StudyBee <no-reply@yourdomain.com>

# Optional: reset token lifetime (seconds)
DJANGO_PASSWORD_RESET_TIMEOUT=86400
