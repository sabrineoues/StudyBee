# Local environment variables (DO NOT COMMIT)
# Fill in your SendGrid key before using SMTP.

STUDYBEE_FRONTEND_URL=http://localhost:5173

# Use SendGrid SMTP
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.sendgrid.net
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_HOST_USER=apikey

# Put your real SendGrid API key here (starts with SG.)
DJANGO_EMAIL_HOST_PASSWORD=

# Must be a verified sender in SendGrid
DJANGO_DEFAULT_FROM_EMAIL=StudyBee <no-reply@yourdomain.com>

DJANGO_PASSWORD_RESET_TIMEOUT=86400
