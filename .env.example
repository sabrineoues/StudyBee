# Copy this file to .env (do not commit .env)
# Gmail SMTP settings for password reset emails
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.gmail.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_HOST_USER=youraddress@gmail.com
DJANGO_EMAIL_HOST_PASSWORD=your_gmail_app_password
DJANGO_DEFAULT_FROM_EMAIL=StudyBee <youraddress@gmail.com>

# Used to generate the reset link inside emails
STUDYBEE_FRONTEND_URL=http://localhost:5173
